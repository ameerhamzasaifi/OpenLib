rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Logo uploads: authenticated users can upload, anyone can read
    match /logos/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 2 * 1024 * 1024
                   // [VULN-I FIX] Block SVG uploads — SVGs can contain <script> and execute in-browser
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }
    // Screenshot uploads: authenticated users can upload, anyone can read
    match /screenshots/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }
    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
