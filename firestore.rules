rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/user_records/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() in ["admin", "openlib-team"];
    }

    function isMaintainerOrAbove() {
      return isSignedIn() && getUserRole() in ["maintainer", "admin", "openlib-team"];
    }

    // ── Apps ──────────────────────────────────────────────────────────────────
    match /apps/{appId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.addedBy.uid == request.auth.uid);
      allow delete: if isAdmin();
    }

    // ── App Versions ─────────────────────────────────────────────────────────
    match /app_versions/{versionId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── App Votes ────────────────────────────────────────────────────────────
    match /app_votes/{voteId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ── App Views (throttle tracking) ────────────────────────────────────────
    match /app_views/{viewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Ratings ──────────────────────────────────────────────────────────────
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── Submissions ──────────────────────────────────────────────────────────
    match /submissions/{submissionId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid
            && resource.data.status in ["pending", "changes_requested"]);
      allow delete: if isAdmin();
    }

    // ── Edit Requests ────────────────────────────────────────────────────────
    match /edit_requests/{editId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isMaintainerOrAbove()
        || (isSignedIn() && resource.data.submitter.uid == request.auth.uid
            && resource.data.status == "open");
      allow delete: if isAdmin();
    }

    // ── Review Comments ──────────────────────────────────────────────────────
    match /review_comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // ── Reports ──────────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── User Records ─────────────────────────────────────────────────────────
    match /user_records/{uid} {
      allow read: if true;
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── Organizations ────────────────────────────────────────────────────────
    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn()
        && resource.data.members.hasAny([
          {"uid": request.auth.uid, "role": "owner"},
          {"uid": request.auth.uid, "role": "maintainer"}
        ]) || isAdmin();
      allow delete: if isAdmin();
    }

    // ── User Activity (recommendations tracking) ─────────────────────────────
    match /user_activity/{activityId} {
      allow read: if isSignedIn()
        && resource.data.uid == request.auth.uid || isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }
  }
}
