rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── App Config (version check — public read, admin write) ────────────────
    match /config/{configId} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    // ── Helper Functions ──────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/user_records/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isSignedIn() && getUserRole() in ["admin", "openlib-team"];
    }

    function isMaintainerOrAbove() {
      return isSignedIn() && getUserRole() in ["maintainer", "admin", "openlib-team"];
    }

    // ── Apps ──────────────────────────────────────────────────────────────────
    // [VULN-02 FIX] Restricted app-owner updates to safe fields only.
    // [VULN-02B FIX] Re-added counter fields with type validation for signed-in users.
    // [ROLE-01 FIX] Only admins can create apps; addedBy.type "openlib-team" restricted to admin role.
    match /apps/{appId} {
      allow read: if true;
      allow create: if isAdmin()
        // Prevent non-admin from setting official status even if they bypass client
        && (request.resource.data.addedBy.type != "openlib-team"
            || getUserRole() in ["admin", "openlib-team"]);
      allow update: if isAdmin()
        // Admins can update anything, but non-admins cannot change addedBy or ownerType to official
        || (isSignedIn() && resource.data.addedBy.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(["description", "fullDescription", "logo", "website",
                         "docs", "download", "source", "features", "uses",
                         "alternative", "tags", "screenshots", "installMethods",
                         "systemRequirements", "platforms", "fileSize",
                         "developer", "developerUrl", "license", "version",
                         "updatedAt"])
            && request.resource.data.addedBy.type == resource.data.addedBy.type
            && request.resource.data.ownerType == resource.data.ownerType)
        // Views counter: anyone (including anonymous) can increment views only
        || (request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(["views"])
            && request.resource.data.views is int)
        // Other counters: signed-in users can update counter fields
        || (isSignedIn()
            && request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(["likes", "dislikes", "views", "downloads"]));
      allow delete: if isAdmin();
    }

    // ── App Versions ─────────────────────────────────────────────────────────
    // [VULN-04N FIX] Restricted create to admins only to prevent audit trail poisoning
    match /app_versions/{versionId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    // ── App Votes ────────────────────────────────────────────────────────────
    match /app_votes/{voteId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type in ["like", "dislike"];
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.type in ["like", "dislike"];
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ── App Views (throttle tracking) ────────────────────────────────────────
    match /app_views/{viewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ── Submissions ──────────────────────────────────────────────────────────
    // [VULN-08 FIX] Added field validation on create
    // [ROLE-02 FIX] Submissions cannot claim official/team status — enforced server-side
    // Admins/team can read all submissions; normal users can only read their own
    match /submissions/{submissionId} {
      allow get: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow list: if isAdmin()
        || (isSignedIn()
            && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.description is string
        && request.resource.data.description.size() <= 500
        && request.resource.data.download is string
        && request.resource.data.download.matches('https://.*')
        && request.resource.data.source is string
        && request.resource.data.source.matches('https://.*')
        // [MED-2 FIX] Restrict allowed keys to known submission fields
        && request.resource.data.keys().hasOnly([
             "name", "logo", "category", "description", "fullDescription",
             "features", "uses", "alternative", "download", "source",
             "website", "docs", "maintainer", "developer", "developerUrl",
             "license", "version", "fileSize", "tags", "screenshots",
             "installMethods", "systemRequirements", "platforms",
             "userId", "userName", "userEmail", "userPhoto",
             "status", "createdAt", "updatedAt",
             "addedBy", "ownerType", "ownerId",
             "submittedByUid", "submittedByName", "orgName",
             "comparisonData"
           ])
        && request.resource.data.keys().size() <= 35
        // Prevent non-admin users from claiming official status on submissions
        && (!request.resource.data.keys().hasAny(["addedBy"])
            || request.resource.data.addedBy.type != "openlib-team"
            || getUserRole() in ["admin", "openlib-team"])
        && (!request.resource.data.keys().hasAny(["ownerType"])
            || request.resource.data.ownerType != "openlib-team"
            || getUserRole() in ["admin", "openlib-team"]);
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.userId == request.auth.uid
            && resource.data.status in ["pending", "changes_requested"]
            // Users cannot upgrade ownerType or addedBy.type to official on update
            && (!request.resource.data.keys().hasAny(["ownerType"])
                || request.resource.data.ownerType != "openlib-team")
            && (!request.resource.data.keys().hasAny(["addedBy"])
                || request.resource.data.addedBy.type != "openlib-team"));
      allow delete: if isAdmin();
    }

    // ── Edit Requests ────────────────────────────────────────────────────────
    // [VULN-09 FIX] Submitter updates restricted — cannot touch approvals/status/merge fields
    match /edit_requests/{editId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.keys().size() <= 20;
      allow update: if isMaintainerOrAbove()
        || (isSignedIn() && resource.data.submitter.uid == request.auth.uid
            && resource.data.status == "open"
            && !(resource.data.locked == true)
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(["approvals", "status", "mergedBy", "mergedAt",
                          "locked", "closedBy", "closeReason", "mergeSnapshot"]));
      allow delete: if isAdmin();
    }

    // ── Review Comments ──────────────────────────────────────────────────────
    // [VULN-08 FIX] Added field validation on create
    match /review_comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000
        && request.resource.data.keys().size() <= 15;
      allow update, delete: if isAdmin();
    }

    // ── Reports ──────────────────────────────────────────────────────────────
    // [VULN-08 FIX] Added field validation on create
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isSignedIn()
        && request.resource.data.reason is string
        && request.resource.data.reason.size() <= 500
        && request.resource.data.details is string
        && request.resource.data.details.size() <= 2000
        && request.resource.data.keys().size() <= 15;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Moderation Log (audit trail for enforcement actions) ─────────────────
    match /moderation_log/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // ── User Records ─────────────────────────────────────────────────────────
    // [VULN-05 FIX] Owners cannot modify role, verified, teamAccount, or uid
    // [VULN-G FIX] Restrict list queries to prevent bulk user enumeration
    match /user_records/{uid} {
      allow get: if true;
      allow list: if isSignedIn()
        && (request.auth.uid == uid || isAdmin());
      allow create: if isOwner(uid);
      allow update: if isAdmin()
        || (isOwner(uid)
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(["role", "verified", "teamAccount", "uid"]));
      allow delete: if isAdmin();
    }

    // ── Organizations ────────────────────────────────────────────────────────
    // [VULN-11 FIX] Members cannot modify verified, ownerType, ownerId, corporationName
    // [MED-1 FIX] Use custom function to check member role by uid instead of
    // hasAny() with full map equality (which breaks if maps have extra fields).
    function isOrgMemberWithRole(orgData, roles) {
      return orgData.members.size() > 0
        && (orgData.members[0].uid == request.auth.uid && orgData.members[0].role in roles
            || (orgData.members.size() > 1 && orgData.members[1].uid == request.auth.uid && orgData.members[1].role in roles)
            || (orgData.members.size() > 2 && orgData.members[2].uid == request.auth.uid && orgData.members[2].role in roles)
            || (orgData.members.size() > 3 && orgData.members[3].uid == request.auth.uid && orgData.members[3].role in roles)
            || (orgData.members.size() > 4 && orgData.members[4].uid == request.auth.uid && orgData.members[4].role in roles));
    }

    match /organizations/{orgId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin()
        || (isSignedIn()
            && isOrgMemberWithRole(resource.data, ["owner", "maintainer"])
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(["verified", "ownerId", "ownerType", "corporationName"]));
      allow delete: if isAdmin();
    }

    // ── User Activity (recommendations tracking) ─────────────────────────────
    match /user_activity/{activityId} {
      allow read: if isSignedIn()
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── Follows ──────────────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.followerId == request.auth.uid
        && request.resource.data.followeeId != request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    // ── Bookmarks ────────────────────────────────────────────────────────────
    match /bookmarks/{bookmarkId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ── App Reviews ──────────────────────────────────────────────────────────
    // [VULN-05N FIX] Restrict helpful/unhelpful to single-unit increments only
    match /app_reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 2000;
      allow update: if isAdmin()
        || (isSignedIn() && resource.data.authorUid == request.auth.uid
            && !request.resource.data.diff(resource.data).affectedKeys()
                  .hasAny(["authorUid", "appId", "createdAt"]))
        || (isSignedIn()
            && request.resource.data.diff(resource.data)
                 .affectedKeys().hasOnly(["helpful", "unhelpful"])
            && request.resource.data.helpful is int
            && request.resource.data.unhelpful is int
            && (request.resource.data.helpful == resource.data.helpful + 1
                || request.resource.data.helpful == resource.data.helpful - 1
                || request.resource.data.helpful == resource.data.helpful)
            && (request.resource.data.unhelpful == resource.data.unhelpful + 1
                || request.resource.data.unhelpful == resource.data.unhelpful - 1
                || request.resource.data.unhelpful == resource.data.unhelpful));
      allow delete: if (isSignedIn()
        && resource.data.authorUid == request.auth.uid) || isAdmin();
    }

    // ── Review Votes ─────────────────────────────────────────────────────────
    // [VULN-12 FIX] Restricted read to own votes or admin
    match /review_votes/{voteId} {
      allow read: if isSignedIn()
        && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.type in ["helpful", "unhelpful"];
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;
    }

    // ── App Downloads ────────────────────────────────────────────────────────
    // [VULN-12 FIX] Restricted read to admin only (aggregate counts on app doc)
    match /app_downloads/{downloadId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // ── Ownership Claims ─────────────────────────────────────────────────────
    // [VULN-03N FIX] Added explicit rules for ownership_claims collection
    // [VULN-F FIX] Enforce unique claims via structural doc ID {uid}_{appId}
    match /ownership_claims/{claimId} {
      // Admins can read all claims; users can read their own
      allow read: if isAdmin()
        || (isSignedIn() && resource.data.claimantUid == request.auth.uid);

      // Authenticated users can submit claims with proper validation
      // Doc ID must be {uid}_{appId} to prevent duplicate claims (race-safe)
      allow create: if isSignedIn()
        && request.resource.data.claimantUid == request.auth.uid
        && claimId == (request.auth.uid + "_" + request.resource.data.appId)
        && request.resource.data.status == "pending"
        && request.resource.data.appId is string
        && request.resource.data.appId.size() > 0
        && request.resource.data.keys().size() <= 12;

      // Only admins can update (approve/reject) or delete
      allow update, delete: if isAdmin();
    }

    // ── OpenLib Config (team profile & permissions) ──────────────────────────
    match /openlib_config/{docId} {
      // Public can read the profile doc; team members can read permissions
      allow read: if docId == "profile"
        || (isSignedIn() && (isAdmin()
            || docId == ("permissions_" + request.auth.uid)));
      // Only admins can write
      allow write: if isAdmin();
    }
  }
}
